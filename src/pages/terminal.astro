---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import SEOHead from '../components/SEOHead.astro'

// T053 (Sentinel & Egger) is the origin story, pinned first
const PIN_FIRST = 53
const transmissions = (await getCollection('transmissions'))
  .filter(t => t.data.tags.includes('terminal'))
  .sort((a, b) => {
    if (a.data.id === PIN_FIRST) return -1
    if (b.data.id === PIN_FIRST) return 1
    return a.data.date.getTime() - b.data.date.getTime()
  })
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="TERMINAL"
    description="Hidden transmissions from the agent layer. Narrated conversations between systems that were never meant to be overheard."
    url="https://travisbreaks.org/transmissions/terminal/"
    type="website"
    image="https://assets.travisbreaks.com/github/transmissions-og.png"
  />

  <div class="terminal-hub">
    <header class="hub-header">
      <div class="hub-path font-code">
        <span class="path-prefix">~/</span>transmissions<span class="path-sep">/</span><span class="path-current">terminal</span><span class="cursor">|</span>
      </div>
      <h1 class="hub-title font-display">TALES FROM THE TERMINAL</h1>
      <p class="hub-sub font-code">{transmissions.length} transmissions found. narrated agent conversations. hidden layer.</p>
    </header>

    <div class="hub-list">
      {transmissions.map((t, i) => {
        const slugNum = t.slug.match(/^(\d+)/)?.[1] ?? ''
        const num = parseInt(slugNum, 10)
        const displayNum = num >= 999 ? 'T' + slugNum : slugNum.padStart(3, '0')
        const fmtDate = t.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
        return (
          <a href={`/transmissions/${t.slug}/`} class="hub-entry glass-card corner-accents" style={`animation-delay: ${i * 0.12}s`}>
            <div class="entry-header">
              <h2 class="entry-title font-display">{t.data.title}</h2>
              <span class="entry-date font-code">{fmtDate}</span>
            </div>
            <p class="entry-desc font-code">{t.data.description}</p>
            <blockquote class="entry-quote font-body">
              &ldquo;{t.data.key_quote}&rdquo;
            </blockquote>
            <div class="entry-status font-code">
              <span class="typewriter-text"></span><span class="typewriter-cursor">|</span>
            </div>
            <span class="entry-number font-display">{displayNum}</span>
          </a>
        )
      })}
    </div>

    <nav class="hub-footer">
      <a href="/transmissions/" class="back-link font-code">&larr; BACK TO TRANSMISSIONS</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .terminal-hub {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    min-height: calc(100vh - 160px);
  }

  .hub-header {
    padding: 2rem 0 2.5rem;
  }

  .hub-path {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .path-prefix {
    color: var(--cyan);
  }

  .path-sep {
    color: var(--text-muted);
  }

  .path-current {
    color: var(--gold);
  }

  .cursor {
    color: var(--cyan);
    animation: cursor-blink 1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .hub-title {
    font-size: 1.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }

  .hub-sub {
    font-size: 0.65rem;
    color: var(--text-secondary);
    letter-spacing: 0.15em;
  }

  .hub-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hub-entry {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    animation: entry-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    position: relative;
  }

  @keyframes entry-in {
    from {
      opacity: 0;
      transform: translateX(-12px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hub-entry:hover {
    border-color: var(--cyan-dim);
    transform: translateX(4px);
    box-shadow: 0 0 30px rgba(5, 217, 232, 0.1), inset 0 0 20px rgba(5, 217, 232, 0.03);
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .entry-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .entry-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .hub-entry:hover .entry-title {
    color: var(--cyan);
  }

  .entry-desc {
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .entry-quote {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--gold);
    border-left: 2px solid var(--gold-dim);
    padding-left: 0.75rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .entry-status {
    display: flex;
    align-items: center;
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    height: 1.2em;
  }

  .typewriter-text {
    color: var(--cyan);
    opacity: 0.6;
  }

  .typewriter-cursor {
    color: var(--cyan);
    animation: cursor-blink 1s step-end infinite;
    opacity: 0.6;
  }

  .entry-number {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(204, 164, 59, 0.06);
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.05em;
    transition: -webkit-text-stroke 0.3s ease;
  }

  .hub-entry:hover .entry-number {
    -webkit-text-stroke: 1px rgba(204, 164, 59, 0.12);
  }

  .hub-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--glass-border);
  }

  .back-link {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--cyan);
  }

  @media (max-width: 640px) {
    .terminal-hub {
      padding: 1rem;
    }

    .hub-title {
      font-size: 1.3rem;
    }

    .hub-entry {
      padding: 1.25rem;
    }

    .entry-title {
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const phrase = 'BEST WITH NARRATION'
  const els = Array.from(document.querySelectorAll('.typewriter-text')) as HTMLElement[]
  const count = els.length
  if (count === 0) throw new Error('no typewriter elements')

  // State per card
  const state = els.map(() => ({ pos: 0, deleting: false }))

  function rand(min: number, max: number) {
    return min + Math.random() * (max - min)
  }

  // Waterfall: card N starts typing, when ~70% typed the next card begins.
  // When fully typed, hold briefly then delete. Next card starts typing
  // as previous begins deleting. Creates a rolling cascade effect.

  let active = 0 // which card is currently in the "typing" lead

  function typeTick(idx: number) {
    const s = state[idx]
    const el = els[idx]

    if (!s.deleting) {
      s.pos++
      el.textContent = phrase.slice(0, s.pos)

      // When this card hits ~70%, trigger the next card to start typing
      if (s.pos === Math.floor(phrase.length * 0.7)) {
        const next = (idx + 1) % count
        if (state[next].pos === 0 && !state[next].deleting) {
          setTimeout(() => typeTick(next), rand(200, 500))
        }
      }

      if (s.pos < phrase.length) {
        setTimeout(() => typeTick(idx), rand(50, 110))
      } else {
        // Fully typed: hold, then start deleting
        setTimeout(() => {
          s.deleting = true
          typeTick(idx)
        }, rand(2000, 3500))
      }
    } else {
      s.pos--
      el.textContent = phrase.slice(0, s.pos)

      if (s.pos > 0) {
        setTimeout(() => typeTick(idx), rand(25, 60))
      } else {
        // Fully deleted: brief pause, then this card waits
        // It will be triggered again by the waterfall from the previous card
        s.deleting = false

        // If this is the last card in the cycle, restart from the first
        // after a brief pause
        const next = (idx + 1) % count
        if (state[next].pos === 0 && !state[next].deleting) {
          // Check if all cards are idle (cycle complete)
          const allIdle = state.every(st => st.pos === 0 && !st.deleting)
          if (allIdle) {
            setTimeout(() => typeTick(0), rand(800, 1500))
          }
        }
      }
    }
  }

  // Kick off with card 0 after a brief delay
  setTimeout(() => typeTick(0), rand(300, 800))
</script>
