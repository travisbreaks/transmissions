---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import SEOHead from '../components/SEOHead.astro'
import TransmissionCard from '../components/TransmissionCard.astro'
import EmailCapture from '../components/EmailCapture.astro'

const transmissions = (await getCollection('transmissions'))
  .filter(t => !t.slug.startsWith('999'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

// Collect all unique tags across entries
const allTags = [...new Set(transmissions.flatMap(t => t.data.tags))].sort()

const description = `${transmissions.length} philosophical transmissions on AI interaction, consciousness, grief, and creative process. By Travis Bonnet.`
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="TRANSMISSIONS"
    description={description}
    url="https://travisbreaks.org/transmissions/"
    type="website"
    image="https://assets.travisbreaks.com/github/transmissions-og.png"
  />

  <div class="archive">
    <!-- Header -->
    <header class="archive-header">
      <h1 class="archive-title font-display">
        <span class="title-prefix">03 //</span> TRANSMISSIONS
      </h1>
      <p class="archive-count font-code">
        <span class="count-number" id="count-display" data-target={transmissions.length}>0</span>
        <span id="visible-count" style="display:none">{transmissions.length}</span> TRANSMISSIONS IN ARCHIVE
      </p>
    </header>

    <!-- Filter bar -->
    <div class="filter-bar glass-card corner-accents" style="position:relative;z-index:10;">
      <div class="search-wrapper">
        <input
          type="text"
          id="search-input"
          class="search-input font-code"
          placeholder="SEARCH TRANSMISSIONS..."
          autocomplete="off"
        />
      </div>

      <div class="filter-controls">
        <div class="filter-dropdowns">
          <div class="tag-dropdown" id="tag-dropdown">
            <button class="filter-select font-code" id="tag-toggle">
              TAGS <span class="tag-count" id="tag-count"></span> <span class="dropdown-arrow">&#9662;</span>
            </button>
            <div class="tag-panel" id="tag-panel">
              {allTags.map(tag => (
                <button class="tag-btn font-code" data-filter-tag={tag}>
                  {tag}
                </button>
              ))}
            </div>
          </div>

          <select id="sort-select" class="filter-select font-code">
            <option value="date-desc">NEWEST</option>
            <option value="date-asc">OLDEST</option>
            <option value="title-asc">TITLE A-Z</option>
            <option value="confidence-desc">CONFIDENCE</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Email capture modal (triggers on 40% scroll, once per session) -->
    <EmailCapture
      source="transmissions"
      variant="modal"
      copy={`${transmissions.length} transmissions and counting.`}
    />

    <!-- Grid -->
    <div class="grid" id="transmission-grid">
      {transmissions.map((t, i) => (
        <TransmissionCard
          title={t.data.title}
          slug={t.slug}
          date={t.data.date}
          confidence={t.data.confidence}
          tags={t.data.tags}
          keyQuote={t.data.key_quote}
          summary={t.body?.replace(/<[^>]*>/g, '').replace(/^---[\s\S]*?---/, '').replace(/\n/g, ' ').trim().substring(0, 200) ?? ''}
          index={i}
        />
      ))}
    </div>

    <!-- Empty state -->
    <div class="empty-state font-code" id="empty-state" style="display: none;">
      NO TRANSMISSIONS FOUND
    </div>
  </div>
</BaseLayout>

<script>
  // Simple count-up animation: 0 → target over ~1.5s with eased timing
  ;(function initCounter() {
    const el = document.getElementById('count-display')
    if (!el) return
    const target = parseInt(el.dataset.target || '0', 10)
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (reducedMotion) {
      el.textContent = String(target)
      return
    }

    const duration = 1500
    const start = performance.now()

    function tick(now: number) {
      const elapsed = now - start
      const progress = Math.min(elapsed / duration, 1)
      // Ease-out cubic for smooth deceleration
      const eased = 1 - Math.pow(1 - progress, 3)
      el!.textContent = String(Math.round(eased * target))
      if (progress < 1) requestAnimationFrame(tick)
    }

    // Small delay so it's visible after page paint
    setTimeout(() => requestAnimationFrame(tick), 200)

    // Mirror filter count changes (instant, no animation)
    const hiddenCount = document.getElementById('visible-count')
    if (hiddenCount) {
      const observer = new MutationObserver(() => {
        el!.textContent = hiddenCount.textContent || '0'
      })
      observer.observe(hiddenCount, { childList: true, characterData: true, subtree: true })
    }
  })()

  // Client-side search, filter, and sort (vanilla JS — progressive enhancement)
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const grid = document.getElementById('transmission-grid')!
  const cards = Array.from(grid.querySelectorAll('.card')) as HTMLElement[]
  const tagBtns = document.querySelectorAll('[data-filter-tag]')
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement
  const visibleCount = document.getElementById('visible-count')!
  const emptyState = document.getElementById('empty-state')!

  let activeTags = new Set<string>()

  function filterAndSort() {
    const query = searchInput.value.toLowerCase().trim()
    let visible = 0

    for (const card of cards) {
      const title = card.dataset.title || ''
      const summary = card.dataset.summary || ''
      const cardTags = (card.dataset.tags || '').split(',')

      // Search match
      const matchesSearch = !query
        || title.includes(query)
        || summary.includes(query)
        || cardTags.some(t => t.includes(query))

      // Tag match (all active tags must be present)
      const matchesTags = activeTags.size === 0
        || [...activeTags].every(tag => cardTags.includes(tag))

      if (matchesSearch && matchesTags) {
        card.style.display = ''
        visible++
      } else {
        card.style.display = 'none'
      }
    }

    visibleCount.textContent = String(visible)
    emptyState.style.display = visible === 0 ? '' : 'none'

    // Sort visible cards
    const sortVal = sortSelect.value
    const sorted = cards
      .filter(c => c.style.display !== 'none')
      .sort((a, b) => {
        switch (sortVal) {
          case 'date-desc':
            return (b.dataset.date || '').localeCompare(a.dataset.date || '')
          case 'date-asc':
            return (a.dataset.date || '').localeCompare(b.dataset.date || '')
          case 'title-asc':
            return (a.dataset.title || '').localeCompare(b.dataset.title || '')
          case 'confidence-desc': {
            const confA = parseInt(a.querySelector('.card-confidence')?.textContent || '0')
            const confB = parseInt(b.querySelector('.card-confidence')?.textContent || '0')
            return confB - confA
          }
          default:
            return 0
        }
      })

    // Re-append in order
    for (const card of sorted) grid.appendChild(card)
  }

  searchInput.addEventListener('input', filterAndSort)
  sortSelect.addEventListener('change', filterAndSort)

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.filterTag!
      if (activeTags.has(tag)) {
        activeTags.delete(tag)
        btn.classList.remove('active')
      } else {
        activeTags.add(tag)
        btn.classList.add('active')
      }
      // Update tag count badge
      const countEl = document.getElementById('tag-count')
      if (countEl) countEl.textContent = activeTags.size > 0 ? `(${activeTags.size})` : ''
      filterAndSort()
    })
  })

  // Tag dropdown toggle
  const tagToggle = document.getElementById('tag-toggle')
  const tagPanel = document.getElementById('tag-panel')
  if (tagToggle && tagPanel) {
    tagToggle.addEventListener('click', (e) => {
      e.stopPropagation()
      tagPanel.classList.toggle('open')
    })

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('#tag-dropdown')) {
        tagPanel.classList.remove('open')
      }
    })
  }
</script>

<style>
  .archive {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .archive-header {
    padding: 1.25rem 0 1rem;
    text-align: center;
  }

  .archive-title {
    font-size: 2rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .title-prefix {
    color: var(--gold);
    font-weight: 300;
  }

  .archive-count {
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6em;
  }

  .count-number {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--cyan);
    font-family: var(--font-code);
    letter-spacing: 0.05em;
    min-width: 2ch;
    display: inline-block;
    text-align: center;
  }

  .filter-bar {
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-wrapper {
    width: 100%;
  }

  .search-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    border-color: var(--cyan);
  }

  .filter-controls {
    display: flex;
    justify-content: flex-end;
  }

  .filter-dropdowns {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .filter-select {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    padding: 5px 10px;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .filter-select:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .filter-select option {
    background: var(--void);
  }

  .dropdown-arrow {
    font-size: 0.5em;
    margin-left: 0.3em;
    opacity: 0.5;
  }

  .tag-count {
    color: var(--cyan);
    font-size: 0.5rem;
  }

  .tag-dropdown {
    position: relative;
  }

  .tag-panel {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 180px;
    max-height: 280px;
    overflow-y: auto;
    background: var(--void-surface);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.5rem;
    z-index: 50;
    display: none;
    flex-direction: column;
    gap: 2px;
  }

  .tag-panel.open {
    display: flex;
  }

  .tag-btn {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid transparent;
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
    width: 100%;
  }

  .tag-btn:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .tag-btn.active {
    background: var(--cyan-dim);
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .archive {
      padding: 1rem;
    }

    .archive-title {
      font-size: 1.4rem;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .filter-dropdowns {
      width: 100%;
      justify-content: space-between;
    }

    .tag-panel {
      right: auto;
      left: 0;
      min-width: 160px;
    }
  }
</style>
