---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import SEOHead from '../components/SEOHead.astro'
import TransmissionCard from '../components/TransmissionCard.astro'
import EmailCapture from '../components/EmailCapture.astro'

const transmissions = (await getCollection('transmissions'))
  .filter(t => !t.slug.startsWith('999'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

// Collect all unique tags across entries
const allTags = [...new Set(transmissions.flatMap(t => t.data.tags))].sort()

const description = `${transmissions.length} philosophical transmissions on AI interaction, consciousness, grief, and creative process. By Travis Bonnet.`
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="TRANSMISSIONS"
    description={description}
    url="https://travisbreaks.org/transmissions/"
    type="website"
    image="https://assets.travisbreaks.com/github/transmissions-og.png"
  />

  <div class="archive">
    <!-- Header -->
    <header class="archive-header">
      <h1 class="archive-title font-display">
        <span class="title-prefix">03 //</span> TRANSMISSIONS
      </h1>
      <p class="archive-count font-code">
        <span class="flap-display" id="flap-display" data-target={transmissions.length}></span>
        <span id="visible-count" class="flap-hidden">{transmissions.length}</span> TRANSMISSIONS IN ARCHIVE
      </p>
    </header>

    <!-- Filter bar -->
    <div class="filter-bar glass-card corner-accents">
      <div class="search-wrapper">
        <input
          type="text"
          id="search-input"
          class="search-input font-code"
          placeholder="SEARCH TRANSMISSIONS..."
          autocomplete="off"
        />
      </div>

      <div class="filter-controls">
        <div class="filter-dropdowns">
          <div class="tag-dropdown" id="tag-dropdown">
            <button class="filter-select font-code" id="tag-toggle">
              TAGS <span class="tag-count" id="tag-count"></span> <span class="dropdown-arrow">&#9662;</span>
            </button>
            <div class="tag-panel" id="tag-panel">
              {allTags.map(tag => (
                <button class="tag-btn font-code" data-filter-tag={tag}>
                  {tag}
                </button>
              ))}
            </div>
          </div>

          <select id="sort-select" class="filter-select font-code">
            <option value="date-desc">NEWEST</option>
            <option value="date-asc">OLDEST</option>
            <option value="title-asc">TITLE A-Z</option>
            <option value="confidence-desc">CONFIDENCE</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Email capture modal (triggers on 40% scroll, once per session) -->
    <EmailCapture
      source="transmissions"
      variant="modal"
      copy={`${transmissions.length} transmissions and counting.`}
    />

    <!-- Grid -->
    <div class="grid" id="transmission-grid">
      {transmissions.map((t, i) => (
        <TransmissionCard
          title={t.data.title}
          slug={t.slug}
          date={t.data.date}
          confidence={t.data.confidence}
          tags={t.data.tags}
          keyQuote={t.data.key_quote}
          summary={t.body?.substring(0, 200) ?? ''}
          index={i}
        />
      ))}
    </div>

    <!-- Empty state -->
    <div class="empty-state font-code" id="empty-state" style="display: none;">
      NO TRANSMISSIONS FOUND
    </div>
  </div>
</BaseLayout>

<script>
  // Split-flap / Solari board counter animation
  ;(function initFlap() {
    const display = document.getElementById('flap-display')
    if (!display) return
    const target = parseInt(display.dataset.target || '0', 10)
    const digits = String(target).split('')
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    function buildDigit(value: string): HTMLElement {
      const el = document.createElement('span')
      el.className = 'flap-digit'
      // 4-layer structure:
      // 1. upper-static: top half showing current number (clipped)
      // 2. lower-static: bottom half showing current number (clipped)
      // 3. flip-top: the card that falls forward (old number top half)
      // 4. flip-bottom: the card that falls into place (new number bottom half)
      el.innerHTML = `
        <span class="flap-upper"><span class="flap-num">${value}</span></span>
        <span class="flap-lower"><span class="flap-num">${value}</span></span>
        <span class="flap-card-top"><span class="flap-num">${value}</span></span>
        <span class="flap-card-bottom"><span class="flap-num">${value}</span></span>
      `
      return el
    }

    function setDigitValue(el: HTMLElement, val: string) {
      el.querySelectorAll('.flap-num').forEach(n => n.textContent = val)
    }

    function flipDigit(el: HTMLElement, from: string, to: string): Promise<void> {
      return new Promise(resolve => {
        const upper = el.querySelector('.flap-upper .flap-num') as HTMLElement
        const lower = el.querySelector('.flap-lower .flap-num') as HTMLElement
        const cardTop = el.querySelector('.flap-card-top') as HTMLElement
        const cardBottom = el.querySelector('.flap-card-bottom') as HTMLElement

        // Static layers show the NEW value (revealed as cards flip)
        upper.textContent = to
        lower.textContent = to

        // Top card shows OLD value, will flip down to reveal new upper
        cardTop.querySelector('.flap-num')!.textContent = from
        cardTop.style.transform = 'rotateX(0deg)'
        cardTop.style.display = ''

        // Bottom card shows NEW value, starts hidden (flipped up), falls into place
        cardBottom.querySelector('.flap-num')!.textContent = to
        cardBottom.style.transform = 'rotateX(90deg)'
        cardBottom.style.display = ''

        // Phase 1: top card falls forward
        requestAnimationFrame(() => {
          cardTop.style.transition = 'transform 0.15s ease-in'
          cardTop.style.transform = 'rotateX(-90deg)'

          // Phase 2: after top falls, bottom card swings into place
          setTimeout(() => {
            cardTop.style.display = 'none'
            cardBottom.style.transition = 'transform 0.2s ease-out'
            cardBottom.style.transform = 'rotateX(0deg)'

            setTimeout(() => {
              cardBottom.style.display = 'none'
              resolve()
            }, 200)
          }, 150)
        })
      })
    }

    // Build digit elements
    digits.forEach((finalDigit, i) => {
      const el = buildDigit(reducedMotion ? finalDigit : '0')
      display.appendChild(el)

      if (reducedMotion) return

      const final = parseInt(finalDigit, 10)
      let current = 0
      const stagger = i * 120

      setTimeout(async () => {
        for (let n = 1; n <= final; n++) {
          await flipDigit(el, String(n - 1), String(n))
          // Brief pause between flips for that mechanical feel
          await new Promise(r => setTimeout(r, 30 + Math.random() * 20))
        }
      }, stagger)
    })

    // Mirror filter count changes to flap display
    const hiddenCount = document.getElementById('visible-count')
    if (hiddenCount) {
      const observer = new MutationObserver(() => {
        const newVal = hiddenCount.textContent || '0'
        const newDigits = newVal.split('')
        const existing = display.querySelectorAll('.flap-digit')

        if (existing.length !== newDigits.length) {
          display.innerHTML = ''
          newDigits.forEach(d => display.appendChild(buildDigit(d)))
        } else {
          existing.forEach((el, i) => setDigitValue(el as HTMLElement, newDigits[i]))
        }
      })
      observer.observe(hiddenCount, { childList: true, characterData: true, subtree: true })
    }
  })()

  // Client-side search, filter, and sort (vanilla JS — progressive enhancement)
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const grid = document.getElementById('transmission-grid')!
  const cards = Array.from(grid.querySelectorAll('.card')) as HTMLElement[]
  const tagBtns = document.querySelectorAll('[data-filter-tag]')
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement
  const visibleCount = document.getElementById('visible-count')!
  const emptyState = document.getElementById('empty-state')!

  let activeTags = new Set<string>()

  function filterAndSort() {
    const query = searchInput.value.toLowerCase().trim()
    let visible = 0

    for (const card of cards) {
      const title = card.dataset.title || ''
      const summary = card.dataset.summary || ''
      const cardTags = (card.dataset.tags || '').split(',')

      // Search match
      const matchesSearch = !query
        || title.includes(query)
        || summary.includes(query)
        || cardTags.some(t => t.includes(query))

      // Tag match (all active tags must be present)
      const matchesTags = activeTags.size === 0
        || [...activeTags].every(tag => cardTags.includes(tag))

      if (matchesSearch && matchesTags) {
        card.style.display = ''
        visible++
      } else {
        card.style.display = 'none'
      }
    }

    visibleCount.textContent = String(visible)
    emptyState.style.display = visible === 0 ? '' : 'none'

    // Sort visible cards
    const sortVal = sortSelect.value
    const sorted = cards
      .filter(c => c.style.display !== 'none')
      .sort((a, b) => {
        switch (sortVal) {
          case 'date-desc':
            return (b.dataset.date || '').localeCompare(a.dataset.date || '')
          case 'date-asc':
            return (a.dataset.date || '').localeCompare(b.dataset.date || '')
          case 'title-asc':
            return (a.dataset.title || '').localeCompare(b.dataset.title || '')
          case 'confidence-desc': {
            const confA = parseInt(a.querySelector('.card-confidence')?.textContent || '0')
            const confB = parseInt(b.querySelector('.card-confidence')?.textContent || '0')
            return confB - confA
          }
          default:
            return 0
        }
      })

    // Re-append in order
    for (const card of sorted) grid.appendChild(card)
  }

  searchInput.addEventListener('input', filterAndSort)
  sortSelect.addEventListener('change', filterAndSort)

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.filterTag!
      if (activeTags.has(tag)) {
        activeTags.delete(tag)
        btn.classList.remove('active')
      } else {
        activeTags.add(tag)
        btn.classList.add('active')
      }
      // Update tag count badge
      const countEl = document.getElementById('tag-count')
      if (countEl) countEl.textContent = activeTags.size > 0 ? `(${activeTags.size})` : ''
      filterAndSort()
    })
  })

  // Tag dropdown toggle
  const tagToggle = document.getElementById('tag-toggle')
  const tagPanel = document.getElementById('tag-panel')
  if (tagToggle && tagPanel) {
    tagToggle.addEventListener('click', (e) => {
      e.stopPropagation()
      tagPanel.classList.toggle('open')
    })

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('#tag-dropdown')) {
        tagPanel.classList.remove('open')
      }
    })
  }
</script>

<style>
  .archive {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .archive-header {
    padding: 1.25rem 0 1rem;
    text-align: center;
  }

  .archive-title {
    font-size: 2rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .title-prefix {
    color: var(--gold);
    font-weight: 300;
  }

  .archive-count {
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
  }

  .flap-hidden {
    display: none;
  }

  .flap-display {
    display: inline-flex;
    gap: 3px;
  }

  .flap-digit {
    display: inline-block;
    position: relative;
    width: 1.4em;
    height: 1.8em;
    perspective: 200px;
    border-radius: 3px;
    overflow: visible;
  }

  /* Shared half-panel base */
  .flap-upper, .flap-lower,
  .flap-card-top, .flap-card-bottom {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    backface-visibility: hidden;
  }

  /* Static upper half */
  .flap-upper {
    top: 0;
    background: linear-gradient(180deg, #1a1a1a 0%, #141414 100%);
    border: 1px solid rgba(5, 217, 232, 0.06);
    border-bottom: none;
    border-radius: 3px 3px 0 0;
    z-index: 1;
  }

  /* Static lower half */
  .flap-lower {
    bottom: 0;
    background: linear-gradient(180deg, #111111 0%, #0e0e0e 100%);
    border: 1px solid rgba(5, 217, 232, 0.06);
    border-top: none;
    border-radius: 0 0 3px 3px;
    z-index: 1;
  }

  /* Top card: old number, hinges down from bottom edge */
  .flap-card-top {
    top: 0;
    background: linear-gradient(180deg, #1a1a1a 0%, #141414 100%);
    border: 1px solid rgba(5, 217, 232, 0.06);
    border-bottom: none;
    border-radius: 3px 3px 0 0;
    transform-origin: bottom center;
    z-index: 3;
    display: none;
  }

  /* Bottom card: new number, hinges down from top edge */
  .flap-card-bottom {
    bottom: 0;
    background: linear-gradient(180deg, #111111 0%, #0e0e0e 100%);
    border: 1px solid rgba(5, 217, 232, 0.06);
    border-top: none;
    border-radius: 0 0 3px 3px;
    transform-origin: top center;
    z-index: 3;
    display: none;
  }

  /* Center split line */
  .flap-digit::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: rgba(0, 0, 0, 0.7);
    box-shadow: 0 1px 0 rgba(5, 217, 232, 0.04);
    z-index: 5;
    pointer-events: none;
  }

  /* Number text in all panels */
  .flap-num {
    font-size: 1.2em;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    display: block;
  }

  /* Upper halves clip bottom of text, lower halves clip top */
  .flap-upper .flap-num,
  .flap-card-top .flap-num {
    transform: translateY(42%);
  }

  .flap-lower .flap-num,
  .flap-card-bottom .flap-num {
    transform: translateY(-42%);
  }

  .filter-bar {
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-wrapper {
    width: 100%;
  }

  .search-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    border-color: var(--cyan);
  }

  .filter-controls {
    display: flex;
    justify-content: flex-end;
  }

  .filter-dropdowns {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .filter-select {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    padding: 5px 10px;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .filter-select:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .filter-select option {
    background: var(--void);
  }

  .dropdown-arrow {
    font-size: 0.5em;
    margin-left: 0.3em;
    opacity: 0.5;
  }

  .tag-count {
    color: var(--cyan);
    font-size: 0.5rem;
  }

  .tag-dropdown {
    position: relative;
  }

  .tag-panel {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 180px;
    max-height: 280px;
    overflow-y: auto;
    background: var(--void-surface);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.5rem;
    z-index: 50;
    display: none;
    flex-direction: column;
    gap: 2px;
  }

  .tag-panel.open {
    display: flex;
  }

  .tag-btn {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid transparent;
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
    width: 100%;
  }

  .tag-btn:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .tag-btn.active {
    background: var(--cyan-dim);
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .archive {
      padding: 1rem;
    }

    .archive-title {
      font-size: 1.4rem;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .filter-dropdowns {
      width: 100%;
      justify-content: space-between;
    }

    .tag-panel {
      right: auto;
      left: 0;
      min-width: 160px;
    }
  }
</style>
