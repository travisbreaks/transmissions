---
import '../styles/global.css'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="alternate" type="application/rss+xml" title="TRANSMISSIONS // PROTOCOL" href="/transmissions/rss.xml" />
    <slot name="head" />
  </head>
  <body class={className}>
    <!-- Grain overlay -->
    <div class="grain" aria-hidden="true">
      <svg>
        <filter id="grain-filter">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#grain-filter)" />
      </svg>
    </div>

    <!-- Scan line -->
    <div class="scanline" aria-hidden="true"></div>

    <!-- Navigation -->
    <nav class="site-nav">
      <div class="nav-left">
        <a href="/transmissions/" class="nav-brand">
          <span class="nav-label font-code">TRANSMISSIONS</span>
          <span class="nav-separator">//</span>
          <span class="nav-sublabel font-code">PROTOCOL</span>
        </a>
        <div class="nav-status" aria-hidden="true">
          <span class="led led-cyan"></span>
          <span class="led led-gold"></span>
          <span class="nav-status-text font-code">ONLINE</span>
        </div>
      </div>
      <div class="nav-right">
        <a href="https://github.com/travisbreaks" class="nav-icon" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <a href="/" class="nav-back font-code">
          &larr; TRAVISBREAKS.ORG
        </a>
      </div>
    </nav>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-line"></div>
      <p class="font-code">&copy; {new Date().getFullYear()} TRAVIS BREAKS // PROTOCOL</p>
    </footer>
  </body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: var(--glass);
    border-bottom: 1px solid var(--glass-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .site-nav::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--scroll-pct, 0%);
    background: linear-gradient(90deg, rgba(204, 164, 59, 0.08), rgba(5, 217, 232, 0.10));
    z-index: 0;
    pointer-events: none;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-brand:hover {
    color: var(--cyan);
  }

  .nav-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .nav-separator {
    color: var(--gold);
    font-weight: 300;
  }

  .nav-sublabel {
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
  }

  .nav-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-status-text {
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    margin-left: 0.2rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .nav-icon {
    color: var(--text-secondary);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .nav-icon:hover {
    color: var(--cyan);
  }

  .nav-back {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-back::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cyan);
    transition: width 0.3s ease;
  }

  .nav-back:hover {
    color: var(--cyan);
  }

  .nav-back:hover::after {
    width: 100%;
  }

  main {
    min-height: calc(100vh - 120px);
  }

  .site-footer {
    padding: 2rem;
    text-align: center;
  }

  .footer-line {
    width: 60px;
    height: 1px;
    background: var(--gold-dim);
    margin: 0 auto 1rem;
  }

  .site-footer p {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  @media (max-width: 768px) {
    .site-nav {
      padding: 0.75rem 1rem;
    }

    .nav-sublabel,
    .nav-status {
      display: none;
    }
  }
</style>

<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      const top = document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const pct = height > 0 ? (top / height) * 100 : 0;
      (nav as HTMLElement).style.setProperty('--scroll-pct', pct + '%');
    }, { passive: true });
  }
</script>
