---
interface Props {
  title: string
  description: string
  url: string
  type?: 'article' | 'website'
  datePublished?: string
  tags?: string[]
  keyQuote?: string
  image?: string
  wordCount?: number
  readTime?: number
}

const { title, description, url, type = 'website', datePublished, tags, keyQuote, image, wordCount, readTime } = Astro.props
const fullTitle = `${title} | TRANSMISSIONS // PROTOCOL`
const siteName = 'TRAVIS BREAKS // PROTOCOL'
const author = 'Travis Bonnet'
---

<!-- Standard -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
{tags && <meta name="keywords" content={tags.join(', ')} />}
<link rel="canonical" href={url} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
{image && <meta property="og:image" content={image} />}
{image && <meta property="og:image:width" content="1200" />}
{image && <meta property="og:image:height" content="630" />}
{datePublished && <meta property="article:published_time" content={datePublished} />}
{tags && tags.map(tag => <meta property="article:tag" content={tag} />)}
{type === 'article' && <meta property="article:author" content="https://travisbreaks.org" />}

<!-- Twitter -->
<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{image && <meta name="twitter:image" content={image} />}

<!-- JSON-LD Structured Data -->
{type === 'article' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: description,
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': url,
    },
    author: {
      '@type': 'Person',
      name: author,
      url: 'https://travisbreaks.org',
      sameAs: [
        'https://github.com/travisbreaks',
        'https://soundcloud.com/travisbreaks',
      ],
    },
    datePublished: datePublished,
    publisher: {
      '@type': 'Person',
      name: author,
      url: 'https://travisbreaks.org',
    },
    url: url,
    ...(image && { image }),
    keywords: tags?.join(', '),
    ...(wordCount && { wordCount }),
    ...(readTime && { timeRequired: `PT${readTime}M` }),
    inLanguage: 'en-US',
    ...(keyQuote && {
      citation: {
        '@type': 'CreativeWork',
        text: keyQuote,
        author: { '@type': 'Person', name: author },
      },
    }),
  })} />
)}

{type === 'article' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'TRAVISBREAKS',
        item: 'https://travisbreaks.org/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'TRANSMISSIONS',
        item: 'https://travisbreaks.org/transmissions/',
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: title,
        item: url,
      },
    ],
  })} />
)}

{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'TRANSMISSIONS',
    description: description,
    url: url,
    author: {
      '@type': 'Person',
      name: author,
      url: 'https://travisbreaks.org',
    },
    isPartOf: {
      '@type': 'WebSite',
      name: siteName,
      url: 'https://travisbreaks.org',
    },
  })} />
)}
