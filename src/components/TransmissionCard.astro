---
interface Props {
  title: string
  slug: string
  date: Date
  confidence: number
  tags: string[]
  keyQuote: string
  summary: string
  index?: number
}

const { title, slug, date, confidence, tags, keyQuote, summary, index = 0 } = Astro.props
const slugNumber = slug.match(/^(\d+)/)?.[1]
const displayNumber = slugNumber ? slugNumber.padStart(3, '0') : ''

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
})

// Show first 3 tags, "+N more" if overflow
const visibleTags = tags.slice(0, 3)
const overflowCount = tags.length - 3
---

<a
  href={`/transmissions/${slug}/`}
  class="card corner-accents glass-card glow-hover card-animate"
  data-title={title.toLowerCase()}
  data-tags={tags.join(',')}
  data-date={date.toISOString()}
  data-summary={summary.toLowerCase()}
  style={`animation-delay: ${index * 0.05}s`}
>
  <div class="card-header">
    <span class="card-date font-code">{formattedDate}</span>
    <span class="card-confidence font-code">{confidence}%</span>
  </div>

  <h2 class="card-title font-display">{title}</h2>

  <p class="card-summary font-body">{summary}</p>

  <blockquote class="card-quote font-body">
    &ldquo;{keyQuote}&rdquo;
  </blockquote>

  <div class="card-tags">
    {visibleTags.map(tag => (
      <span class="tag font-code" data-tag={tag}>{tag}</span>
    ))}
    {overflowCount > 0 && (
      <span class="tag tag-overflow font-code">+{overflowCount}</span>
    )}
  </div>

  {displayNumber && (
    <span
      class="card-number font-display"
      style={`--sheen-duration: ${7 + (index % 7) * 1.3}s; --sheen-delay: ${(index * 1.7) % 5}s`}
    >{displayNumber}</span>
  )}
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.3s ease, transform 0.2s ease;
    position: relative;
  }

  .card:hover {
    border-color: var(--cyan-dim);
    transform: translateY(-2px);
  }

  .card:hover .card-title {
    color: var(--cyan);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-date {
    font-size: 0.65rem;
    color: var(--text-secondary);
    letter-spacing: 0.1em;
  }

  .card-confidence {
    font-size: 0.6rem;
    color: var(--gold);
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border: 1px solid var(--gold-dim);
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .card-summary {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-quote {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--gold);
    border-left: 2px solid var(--gold-dim);
    padding-left: 0.75rem;
    line-height: 1.5;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  .tag {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid var(--cyan-dim);
    padding: 2px 8px;
    transition: background 0.2s ease;
  }

  .card:hover .tag {
    background: var(--cyan-dim);
  }

  .tag-overflow {
    color: var(--text-muted);
    border-color: var(--glass-border);
  }

  .card-number {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(204, 164, 59, 0.06);
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.05em;
    transition: -webkit-text-stroke 0.3s ease;
  }

  .card:hover .card-number {
    -webkit-text-stroke: 1px rgba(204, 164, 59, 0.12);
  }
</style>
